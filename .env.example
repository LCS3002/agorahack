# Copy to `.env.local` and fill in values. Never commit real keys.

# --- LLM (pick one path) ---
# Primary: OpenAI-compatible API. TNG (AgoraHacks / TUM.ai) example:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://external.model.tngtech.com/v1/
# Required by TNG: your team slug for the x-user-agent header (same as organizer Python).
TEAM_NAME=
# Models: optional if OPENAI_BASE_URL contains tngtech.com — defaults to tngtech/R1T2-Chimera-Speed.
# Otherwise classify defaults to gpt-4o-mini, agent to gpt-4o.
# OPENAI_MODEL_CLASSIFY=tngtech/TNG-The-Artist
# OPENAI_MODEL_AGENT=tngtech/R1T2-Chimera-Speed
#
# TNG: reasoning split (unset + tngtech.com URL → defaults to header). To disable: OPENAI_SEPARATE_REASONING=off
# OPENAI_SEPARATE_REASONING=header
# OPENAI_SEPARATE_REASONING=body
# OPENAI_SEPARATE_REASONING=off

# Official OpenAI: leave OPENAI_BASE_URL unset (or set https://api.openai.com/v1).
# Optional overrides for non-TNG:
# OPENAI_MODEL_CLASSIFY=gpt-4o-mini
# OPENAI_MODEL_AGENT=gpt-4o

# Alias for TEAM_NAME (if you prefer a namespaced var):
# TUM_AI_TEAM_NAME=

# Fallback if OPENAI_API_KEY is unset:
# ANTHROPIC_API_KEY=
